{
  "name": "@powerhousedao/mara-cli",
  "version": "0.0.1",
  "private": false,
  "type": "module",
  "bin": {
    "ph-mara": "./dist/main.js"
  },
  "scripts": {
    "build:skills": "tsx scripts/build-skills.ts",
    "build": "pnpm build:skills && tsc",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --detectOpenHandles"
  },
  "dependencies": {
    "@mastra/core": "^1.22.0",
    "@mastra/libsql": "^1.7.4",
    "@mastra/loggers": "^1.1.0",
    "@mastra/mcp": "^1.4.1",
    "@mastra/memory": "^1.13.1",
    "@powerhousedao/ph-clint": "file:../../packages/ph-clint",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "mastra>@mastra/deployer": "1.22.0"
    }
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/node": "^25.5.2",
    "jest": "^30.2.0",
    "@powerhousedao/ph-clint-dev": "file:../../packages/ph-clint-dev",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  }
}
