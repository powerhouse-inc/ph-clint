  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test:types": "tsc --noEmit -p tests/types/tsconfig.json",
    "test": "pnpm test:types && NODE_OPTIONS='--experimental-vm-modules' jest --coverage --maxWorkers=4"
  },
