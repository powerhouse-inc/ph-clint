{
  "name": "@powerhousedao/ph-clint-dev",
  "version": "0.1.0-dev.103",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./publish": {
      "types": "./dist/publish/index.d.ts",
      "import": "./dist/publish/index.js"
    },
    "./manifest": {
      "types": "./dist/manifest/build-manifest.d.ts",
      "import": "./dist/manifest/build-manifest.js"
    },
    "./spec": {
      "types": "./dist/spec/types.d.ts",
      "import": "./dist/spec/types.js"
    },
    "./spec/file": {
      "types": "./dist/spec/file.d.ts",
      "import": "./dist/spec/file.js"
    },
    "./codegen/markers": {
      "types": "./dist/codegen/markers.d.ts",
      "import": "./dist/codegen/markers.js"
    },
    "./codegen/hashes": {
      "types": "./dist/codegen/hashes.d.ts",
      "import": "./dist/codegen/hashes.js"
    },
    "./codegen/write": {
      "types": "./dist/codegen/write.d.ts",
      "import": "./dist/codegen/write.js"
    },
    "./codegen/exec": {
      "types": "./dist/codegen/exec.d.ts",
      "import": "./dist/codegen/exec.js"
    },
    "./codegen/generated": {
      "types": "./dist/codegen/generated.d.ts",
      "import": "./dist/codegen/generated.js"
    },
    "./codegen/builders": {
      "types": "./dist/codegen/builders/index.d.ts",
      "import": "./dist/codegen/builders/index.js"
    },
    "./codegen/types": {
      "types": "./dist/codegen/types.d.ts",
      "import": "./dist/codegen/types.js"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.ts",
      "import": "./dist/codegen/index.js"
    },
    "./codegen/actions": {
      "types": "./dist/codegen/actions.d.ts",
      "import": "./dist/codegen/actions.js"
    },
    "./codegen/scaffold": {
      "types": "./dist/codegen/scaffold.d.ts",
      "import": "./dist/codegen/scaffold.js"
    },
    "./skills/sync": {
      "types": "./dist/skills/sync.d.ts",
      "import": "./dist/skills/sync.js"
    }
  },
  "bin": {
    "build-skills": "./dist/cli.js",
    "ph-publish": "./dist/publish-cli.js",
    "build-manifest": "./dist/manifest/build-manifest.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "lint": "echo no lint configured"
  },
  "dependencies": {
    "@powerhousedao/ph-clint": "workspace:*",
    "handlebars": "^4.7.8",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/node": "^25.5.2",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
