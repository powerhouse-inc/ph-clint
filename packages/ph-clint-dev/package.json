{
  "name": "@powerhousedao/ph-clint-dev",
  "version": "0.1.0-dev.18",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./publish": {
      "types": "./dist/publish/index.d.ts",
      "import": "./dist/publish/index.js"
    }
  },
  "bin": {
    "build-skills": "./dist/cli.js",
    "ph-publish": "./dist/publish-cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "lint": "echo no lint configured"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "@powerhousedao/ph-clint": "^0.1.0-dev.15"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/node": "^25.5.2",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
