{
  "name": "ph-clint-packages",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm --filter '@powerhousedao/ph-clint' --filter '@powerhousedao/ph-clint-dev' --filter '@powerhousedao/ph-clint-cli' run test && node scripts/merge-coverage.mjs",
    "lint": "pnpm -r run lint",
    "dev": "pnpm -r --parallel run dev",
    "publish:dev": "tsx ph-clint-dev/src/publish-cli.ts dev -c ./publish.config.js",
    "publish:staging": "tsx ph-clint-dev/src/publish-cli.ts staging -c ./publish.config.js",
    "publish:production": "tsx ph-clint-dev/src/publish-cli.ts production -c ./publish.config.js"
  },
  "devDependencies": {
    "nyc": "^18.0.0",
    "tsx": "^4.19.0"
  }
}
