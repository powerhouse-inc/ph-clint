{
  "name": "@powerhousedao/ph-clint-cli",
  "version": "0.1.0-dev.68",
  "publishConfig": {
    "access": "public"
  },
  "description": "ph-clint CLI — scaffolds and maintains ph-clint implementation projects. Itself built with ph-clint from the ph-clint-tpl template.",
  "type": "module",
  "bin": {
    "ph-clint": "./dist/main.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:skills": "tsx scripts/build-skills.ts",
    "build": "pnpm build:skills && tsc",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --detectOpenHandles --coverage",
    "test:e2e": "NODE_OPTIONS='--experimental-vm-modules' jest --detectOpenHandles --testPathPatterns 'tests/(e2e|codegen-e2e)/' --testPathIgnorePatterns '/node_modules/'",
    "lint": "eslint src",
    "mastra:dev": "mastra dev",
    "mastra:build": "mastra build",
    "mastra:start": "mastra start"
  },
  "dependencies": {
    "@electric-sql/pglite": "0.3.15",
    "@mastra/core": "^1.22.0",
    "@mastra/libsql": "^1.7.4",
    "@mastra/memory": "^1.13.1",
    "@powerhousedao/ph-clint": "workspace:*",
    "@powerhousedao/ph-clint-app": "workspace:*",
    "@powerhousedao/ph-clint-dev": "workspace:*",
    "@powerhousedao/reactor": "6.0.0-dev.216",
    "@powerhousedao/reactor-api": "6.0.0-dev.216",
    "@powerhousedao/shared": "6.0.0-dev.216",
    "document-model": "6.0.0-dev.216",
    "kysely": "^0.27.0",
    "kysely-pglite-dialect": "^1.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/node": "^25.5.2",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
