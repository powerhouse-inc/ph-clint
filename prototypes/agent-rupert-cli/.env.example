# Required: Anthropic API key for the weather agent
ANTHROPIC_API_KEY=

# Optional: Host and port for the MCP HTTP/HTTPS server
# MCP_HOST=0.0.0.0
# MCP_PORT=4112

# Optional: Bearer token to protect the MCP HTTP server (leave empty to disable auth)
# MCP_AUTH_TOKEN=

# Optional: Workspace and reactor packages paths (relative to project root)
# WORKSPACE_PATH=./tmp/projects
# REACTOR_PACKAGES_PATH=reactor-packages

# Optional: ph CLI version flag for project init (e.g. staging, latest)
# PROJECTS_PH_VERSION=staging
