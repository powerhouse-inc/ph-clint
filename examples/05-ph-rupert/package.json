{
  "name": "@powerhousedao/ph-rupert-cli",
  "version": "0.0.1-dev.6",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "ph-rupert": "./dist/main.js"
  },
  "scripts": {
    "build:skills": "tsx scripts/build-skills.ts",
    "build": "pnpm build:skills && tsc",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --detectOpenHandles",
    "mastra:dev": "mastra dev",
    "mastra:build": "mastra build",
    "mastra:start": "mastra start",
    "publish:dev": "ph-publish dev",
    "publish:staging": "ph-publish staging",
    "publish:production": "ph-publish production"
  },
  "dependencies": {
    "@mastra/core": "^1.22.0",
    "@mastra/libsql": "^1.7.4",
    "@mastra/loggers": "^1.1.0",
    "@mastra/mcp": "^1.4.1",
    "@mastra/memory": "^1.13.1",
    "@powerhousedao/shared": "6.0.0-dev.174",
    "@renown/sdk": "6.0.0-dev.174",
    "@powerhousedao/ph-clint": "file:../../packages/ph-clint",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "mastra>@mastra/deployer": "1.22.0"
    }
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/node": "^25.5.2",
    "jest": "^30.2.0",
    "mastra": "1.3.20",
    "@powerhousedao/ph-clint-dev": "file:../../packages/ph-clint-dev",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  }
}
