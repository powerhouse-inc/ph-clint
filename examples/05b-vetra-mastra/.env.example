VETRA_MASTRA_API_KEY=

# MCP server config
MCP_HOST=0.0.0.0
MCP_PORT=4112
MCP_AUTH_TOKEN=

# Workspace configuration
VETRA_MASTRA_CONNECT_PORT=3000
VETRA_MASTRA_SWITCHBOARD_PORT=4001
VETRA_MASTRA_STARTUP_TIMEOUT=90000
