{
  "name": "@ph-clint/example-vetra-mastra",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "vetra-mastra": "./dist/main.js"
  },
  "scripts": {
    "build:skills": "tsx scripts/build-skills.ts",
    "build": "pnpm build:skills && tsc && rm -rf dist/skills && cp -r skills dist/skills",
    "dev": "tsx src/main.ts",
    "start": "node dist/main.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --detectOpenHandles",
    "mastra:dev": "mastra dev",
    "mastra:build": "mastra build",
    "mastra:start": "mastra start"
  },
  "dependencies": {
    "@mastra/core": "^1.22.0",
    "@mastra/libsql": "^1.7.4",
    "@mastra/loggers": "^1.1.0",
    "@mastra/mcp": "^1.4.1",
    "@mastra/memory": "^1.13.1",
    "handlebars": "^4.7.8",
    "ph-clint": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/node": "^25.5.2",
    "jest": "^30.2.0",
    "mastra": "1.3.20",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  }
}
